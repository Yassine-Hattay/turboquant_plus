```gitignore
# Python
__pycache__/
*.pyc
*.pyo
*.pyd

# Compiled and build artifacts
*.o
*.obj
*.out
*.so
*.dll
*.exe

# Dependencies
.venv/
venv/
env/
node_modules/

# Logs and temp files
*.log
*.tmp
*.swp
*.swo

# Environment variables
.env
.env.local
*.env.*

# Coverage reports
coverage/
htmlcov/
.coverage

# Editors
.vscode/
.idea/

# OS generated files
.DS_Store
Thumbs.db
```